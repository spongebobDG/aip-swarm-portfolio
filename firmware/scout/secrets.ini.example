; Copy this file to `secrets.ini` (same directory) and fill in real values.
; `secrets.ini` is gitignored — never commit the real one.
;
; PlatformIO auto-includes this via `extra_configs = secrets.ini` in
; platformio.ini, so its [env:...] section is merged with the main env.

[env:esp32-s3-scout]
build_flags =
    ${env:esp32-s3-scout.build_flags}
    -D WIFI_SSID=\"AIP_FLEET\"
    -D WIFI_PASS=\"REPLACE_WITH_REAL_PSK\"
