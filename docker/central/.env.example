# Copy to `.env` (same directory) and fill in production values.
# `.env` is gitignored — never commit real secrets.
#
# Docker Compose auto-loads .env from the same directory as
# docker-compose.yml; referenced as ${VAR} in the compose file.

# --- Fleet identity (H9) ---------------------------------------------
# Isolate fleets on the same subnet by assigning unique domain IDs.
# Range 0-232. Default 42 is fine for a single-fleet deployment.
ROS_DOMAIN_ID=42

# --- Vision Pi direct streams ----------------------------------------
# Optional direct RGB/thermal URLs for the fleet dashboard.
# Keep empty to disable direct browser streams.
AIP_VISION_STREAM_URLS=
AIP_THERMAL_STREAM_URLS=

# Optional dashboard JPEG polling fallback.
# 0 = disabled/MJPEG direct. Recommended low-latency fallback:
# AIP_RGB_POLL_MS=300
# AIP_THERMAL_POLL_MS=1000
AIP_VISION_POLL_MS=0
AIP_RGB_POLL_MS=0
AIP_THERMAL_POLL_MS=0

# --- InfluxDB initial admin ------------------------------------------
INFLUXDB_USERNAME=aip
INFLUXDB_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
INFLUXDB_ORG=aip
INFLUXDB_BUCKET=fleet
# Generate with: openssl rand -hex 32
INFLUXDB_ADMIN_TOKEN=REPLACE_WITH_RANDOM_64HEX_TOKEN
