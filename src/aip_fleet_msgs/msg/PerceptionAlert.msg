# Perception alert from thermal+RGB sensor fusion.
#
# Generated by patrol_monitor_node (Pi 4, threshold pass)
# or central_fusion_node (main PC, ML confirmed).
#
# alert_level:
#   0 = NONE
#   1 = WARN  — thermal threshold exceeded, visual unconfirmed
#   2 = HIGH  — thermal + visual (YOLOv8 fire/smoke) both triggered
#
# thermal_zone: thermal pixel index of hotspot (row * 32 + col), -1 if N/A
# rgb_bbox_*  : bounding box in RGB image pixels, -1 if unconfirmed

std_msgs/Header header
string<=32 vehicle_id
uint8  alert_level         # 0=NONE 1=WARN 2=HIGH
float32 max_temp_c         # peak temperature (°C) in thermal frame
int16  thermal_zone        # hotspot pixel index (0..767), -1 = N/A
int32  rgb_bbox_x          # RGB bounding box top-left x, -1 = unconfirmed
int32  rgb_bbox_y
int32  rgb_bbox_w
int32  rgb_bbox_h
float32 confidence         # 0.0~1.0, 0.0 for WARN (threshold only)
geometry_msgs/Point map_position  # estimated map-frame position of hotspot
