<?xml version="1.0"?>
<!--
  AIP Main AGV — differential drive + YDLIDAR-equivalent + IMU

  xacro args:
    namespace  (default: peer_1)  — prefixes all TF frame IDs
    use_sim    (default: true)    — true: gz_ros2_control plugin
                                    false: aip_hardware/MainAGVHardware (real robot)

  Real-vehicle migration:
    Set use_sim:=false and implement aip_hardware/MainAGVHardware
    that reads encoders and drives motors. All ROS2 controllers (diff_drive_controller,
    joint_state_broadcaster) and their YAML configs remain unchanged.
-->
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="main_agv">

  <!-- ===================== Args ===================== -->
  <xacro:arg name="namespace" default="peer_1"/>
  <xacro:arg name="use_sim"   default="true"/>
  <!-- ctrl_yaml: spawn_vehicle.launch.py가 Python 런타임에서 해석한 절대 경로를 주입.
       $(find ...) 는 ament 인덱스 캐시 의존 → 스테일 경로(예: /mnt/c/...) 생성 가능.
       기본값은 xacro 단독 실행 시 호환성 유지용. -->
  <xacro:arg name="ctrl_yaml" default="$(find aip_main_description)/config/ros2_controllers_base.yaml"/>
  <xacro:property name="ns"       value="$(arg namespace)"/>
  <xacro:property name="use_sim"  value="$(arg use_sim)"/>

  <!-- ===================== Dimensions ===================== -->
  <!-- 차체: 230(W)×300(L)×120(H) mm  확정 (2026-05-19) -->
  <xacro:property name="base_w"    value="0.300"/>  <!-- front-back (세로 300mm) -->
  <xacro:property name="base_d"    value="0.230"/>  <!-- left-right (가로 230mm) -->
  <xacro:property name="base_h"    value="0.120"/>  <!-- height -->
  <!-- 구동부: FIT0186 12V 43.8:1 / 바퀴 지름 120mm / 바퀴 간격 290mm  확정 -->
  <xacro:property name="wheel_r"   value="0.060"/>  <!-- 120mm 지름 ÷ 2 -->
  <xacro:property name="wheel_w"   value="0.025"/>
  <xacro:property name="wheel_x"   value="-0.080"/> <!-- drive axle: rear of center -->
  <xacro:property name="axle_y"    value="0.145"/>  <!-- 290mm ÷ 2 -->
  <!-- BCH-32: 볼 지름 53mm → 반경 26.5mm / 전체높이 39mm / 볼돌출 7.4mm
       섀시 설계에서 바퀴(60mm)와 캐스터(39mm) 단차 21mm 반영 완료
       joint z = caster_r - wheel_r = 0.0265 - 0.060 = -0.0335m → 차체 수평 -->
  <xacro:property name="caster_r"  value="0.0265"/>
  <xacro:property name="lidar_r"   value="0.040"/>
  <xacro:property name="lidar_h"   value="0.060"/>
  <xacro:property name="m_base"    value="1.500"/>
  <!-- FIT0186 모터 1개 205g × 2 = 410g → 휠 링크에 모터 질량 포함 -->
  <xacro:property name="m_wheel"   value="0.205"/>
  <xacro:property name="pi"        value="3.14159265"/>

  <!-- ===================== Inertia helpers ===================== -->
  <xacro:macro name="box_inertia" params="m w d h">
    <inertial>
      <mass value="${m}"/>
      <inertia ixx="${m*(d*d+h*h)/12}" ixy="0" ixz="0"
               iyy="${m*(w*w+h*h)/12}" iyz="0"
               izz="${m*(w*w+d*d)/12}"/>
    </inertial>
  </xacro:macro>

  <xacro:macro name="cyl_inertia" params="m r h">
    <inertial>
      <mass value="${m}"/>
      <inertia ixx="${m*(3*r*r+h*h)/12}" ixy="0" ixz="0"
               iyy="${m*(3*r*r+h*h)/12}" iyz="0"
               izz="${m*r*r/2}"/>
    </inertial>
  </xacro:macro>

  <!-- ===================== Base ===================== -->
  <link name="${ns}/base_footprint"/>

  <joint name="base_joint" type="fixed">
    <parent link="${ns}/base_footprint"/>
    <child  link="${ns}/base_link"/>
    <origin xyz="0 0 ${wheel_r}" rpy="0 0 0"/>
  </joint>

  <link name="${ns}/base_link">
    <xacro:box_inertia m="${m_base}" w="${base_w}" d="${base_d}" h="${base_h}"/>
    <visual>
      <origin xyz="0 0 ${base_h/2}" rpy="0 0 0"/>
      <geometry><box size="${base_w} ${base_d} ${base_h}"/></geometry>
      <material name="grey"><color rgba="0.55 0.55 0.55 1"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 ${base_h/2}" rpy="0 0 0"/>
      <geometry><box size="${base_w} ${base_d} ${base_h}"/></geometry>
    </collision>
  </link>

  <!-- ===================== Wheel macro ===================== -->
  <xacro:macro name="wheel" params="side y_sgn">
    <!-- joint name unprefixed — ros2_control uses this exact string -->
    <joint name="${side}_wheel_joint" type="continuous">
      <parent link="${ns}/base_link"/>
      <child  link="${ns}/${side}_wheel"/>
      <origin xyz="${wheel_x} ${y_sgn * axle_y} 0" rpy="${-pi/2} 0 0"/>
      <axis xyz="0 0 1"/>
      <dynamics damping="0.1" friction="0.1"/>
    </joint>
    <link name="${ns}/${side}_wheel">
      <xacro:cyl_inertia m="${m_wheel}" r="${wheel_r}" h="${wheel_w}"/>
      <visual>
        <geometry><cylinder radius="${wheel_r}" length="${wheel_w}"/></geometry>
        <material name="black"><color rgba="0.1 0.1 0.1 1"/></material>
      </visual>
      <collision>
        <geometry><cylinder radius="${wheel_r}" length="${wheel_w}"/></geometry>
        <surface>
          <friction><ode><mu>1.0</mu><mu2>0.5</mu2></ode></friction>
        </surface>
      </collision>
    </link>
    <gazebo reference="${ns}/${side}_wheel">
      <mu1>1.0</mu1><mu2>0.5</mu2>
      <kp>500000</kp><kd>10</kd>
      <visual>
        <!-- 바퀴 하단이 지면(z=0)과 정확히 일치 → Z-fighting 그림자 artifact 억제 -->
        <cast_shadows>false</cast_shadows>
      </visual>
    </gazebo>
  </xacro:macro>

  <xacro:wheel side="left"  y_sgn="1"/>
  <xacro:wheel side="right" y_sgn="-1"/>

  <!-- Caster (front passive sphere) -->
  <joint name="caster_joint" type="fixed">
    <parent link="${ns}/base_link"/>
    <child  link="${ns}/caster"/>
    <origin xyz="${base_w/2 - caster_r - 0.01} 0 ${caster_r - wheel_r}" rpy="0 0 0"/>
  </joint>
  <link name="${ns}/caster">
    <inertial><mass value="0.010"/>
      <inertia ixx="1e-5" ixy="0" ixz="0" iyy="1e-5" iyz="0" izz="1e-5"/>
    </inertial>
    <visual><geometry><sphere radius="${caster_r}"/></geometry>
      <material name="grey"><color rgba="0.55 0.55 0.55 1"/></material>
    </visual>
    <collision><geometry><sphere radius="${caster_r}"/></geometry>
      <surface><friction><ode><mu>0.0</mu><mu2>0.0</mu2></ode></friction></surface>
    </collision>
  </link>
  <gazebo reference="${ns}/caster"><mu1>0.0</mu1><mu2>0.0</mu2></gazebo>

  <!-- ===================== LiDAR ===================== -->
  <joint name="laser_joint" type="fixed">
    <parent link="${ns}/base_link"/>
    <child  link="${ns}/laser_frame"/>
    <origin xyz="0 0 ${base_h + lidar_h/2 + 0.01}" rpy="0 0 0"/>
  </joint>
  <link name="${ns}/laser_frame">
    <inertial><mass value="0.050"/>
      <inertia ixx="1e-4" ixy="0" ixz="0" iyy="1e-4" iyz="0" izz="1e-4"/>
    </inertial>
    <visual>
      <geometry><cylinder radius="${lidar_r}" length="${lidar_h}"/></geometry>
      <material name="blue"><color rgba="0.1 0.1 0.8 1"/></material>
    </visual>
    <collision>
      <geometry><cylinder radius="${lidar_r}" length="${lidar_h}"/></geometry>
    </collision>
  </link>

  <!-- ===================== IMU ===================== -->
  <joint name="imu_joint" type="fixed">
    <parent link="${ns}/base_link"/>
    <child  link="${ns}/imu_frame"/>
    <origin xyz="0 0 ${base_h/2}" rpy="0 0 0"/>
  </joint>
  <link name="${ns}/imu_frame">
    <inertial><mass value="0.001"/>
      <inertia ixx="1e-6" ixy="0" ixz="0" iyy="1e-6" iyz="0" izz="1e-6"/>
    </inertial>
  </link>

  <!-- ===================== 4-DOF Servo Arm =====================
       위치: 차체 후방 상단 (LiDAR 후방 40° 사각 지대)
       구조: arm_mount(고정) → pan(Z) → shoulder(Y) → elbow(Y) → wrist(Y) → thermal_frame
       기본 자세: shoulder=+45° / elbow=-45° / wrist=0° → 전방-수평 지향
       방향 계산: R_y(shoulder+elbow+wrist)×[1,0,0] = R_y(0°)×[1,0,0] = [1,0,0] (수평)
  -->
  <joint name="arm_mount_joint" type="fixed">
    <parent link="${ns}/base_link"/>
    <child  link="${ns}/arm_mount"/>
    <origin xyz="-0.08 0 ${base_h}" rpy="0 0 0"/>
  </joint>
  <link name="${ns}/arm_mount">
    <inertial><mass value="0.030"/>
      <inertia ixx="1e-5" ixy="0" ixz="0" iyy="1e-5" iyz="0" izz="1e-5"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0.015" rpy="0 0 0"/>
      <geometry><cylinder radius="0.012" length="0.030"/></geometry>
      <material name="dark_grey"><color rgba="0.3 0.3 0.3 1"/></material>
    </visual>
  </link>

  <!-- Joint 1: Pan (Z축, ±90°) -->
  <joint name="arm_pan_joint" type="revolute">
    <parent link="${ns}/arm_mount"/>
    <child  link="${ns}/arm_link_1"/>
    <origin xyz="0 0 0.030" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-1.5708" upper="1.5708" effort="2.0" velocity="1.0"/>
    <dynamics damping="0.05" friction="0.01"/>
  </joint>
  <link name="${ns}/arm_link_1">
    <inertial><mass value="0.020"/>
      <!-- ODE stability: Kd*dt/I = 0.05*0.004/0.001 = 0.2 < 1 (was 20 with 1e-5 -> unstable) -->
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0.035" rpy="0 0 0"/>
      <geometry><cylinder radius="0.010" length="0.070"/></geometry>
      <material name="dark_grey"><color rgba="0.3 0.3 0.3 1"/></material>
    </visual>
  </link>

  <!-- Joint 2: Shoulder (Y축, -30°~80°) -->
  <joint name="arm_shoulder_joint" type="revolute">
    <parent link="${ns}/arm_link_1"/>
    <child  link="${ns}/arm_link_2"/>
    <origin xyz="0 0 0.070" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-0.5236" upper="1.3963" effort="2.0" velocity="1.0"/>
    <dynamics damping="2.0" friction="0.5"/>
  </joint>
  <link name="${ns}/arm_link_2">
    <inertial><mass value="0.015"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
    </inertial>
    <visual>
      <origin xyz="0.030 0 0" rpy="0 ${pi/2} 0"/>
      <geometry><cylinder radius="0.008" length="0.060"/></geometry>
      <material name="dark_grey"><color rgba="0.3 0.3 0.3 1"/></material>
    </visual>
  </link>

  <!-- Joint 3: Elbow (Y축, -120°~30°) -->
  <joint name="arm_elbow_joint" type="revolute">
    <parent link="${ns}/arm_link_2"/>
    <child  link="${ns}/arm_link_3"/>
    <origin xyz="0.060 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-2.0944" upper="0.5236" effort="2.0" velocity="1.0"/>
    <dynamics damping="2.0" friction="0.5"/>
  </joint>
  <link name="${ns}/arm_link_3">
    <inertial><mass value="0.010"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
    </inertial>
    <visual>
      <origin xyz="0.025 0 0" rpy="0 ${pi/2} 0"/>
      <geometry><cylinder radius="0.007" length="0.050"/></geometry>
      <material name="dark_grey"><color rgba="0.3 0.3 0.3 1"/></material>
    </visual>
  </link>

  <!-- Joint 4: Wrist/Camera tilt (Y축, ±45°) -->
  <joint name="arm_wrist_joint" type="revolute">
    <parent link="${ns}/arm_link_3"/>
    <child  link="${ns}/thermal_frame"/>
    <origin xyz="0.050 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-0.7854" upper="0.7854" effort="1.0" velocity="1.0"/>
    <dynamics damping="1.0" friction="0.3"/>
  </joint>
  <link name="${ns}/thermal_frame">
    <inertial><mass value="0.005"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.020 0.014 0.004"/></geometry>
      <material name="sensor_blue"><color rgba="0.1 0.3 0.8 1"/></material>
    </visual>
  </link>

  <!-- ===================== ros2_control block =====================
       This is the ONLY difference between sim and real hardware.
       Swap the <plugin> tag and the controller YAML works unchanged.
       ============================================================= -->
  <ros2_control name="${ns}_drive" type="system">
    <hardware>
      <xacro:if value="${use_sim}">
        <!-- Sim: Ignition Fortress physics engine acts as hardware -->
        <plugin>gz_ros2_control/GazeboSimSystem</plugin>
      </xacro:if>
      <xacro:unless value="${use_sim}">
        <!-- Real: implement this plugin to read encoders / drive motors.
             Serial port and encoder pins are configured here as params. -->
        <plugin>aip_hardware/MainAGVHardware</plugin>
        <param name="serial_port">/dev/ttyUSB0</param>
        <param name="baud_rate">115200</param>
      </xacro:unless>
    </hardware>
    <!-- Joint names must be IDENTICAL between sim and real URDF -->
    <joint name="left_wheel_joint">
      <command_interface name="velocity">
        <param name="min">-10.0</param>
        <param name="max"> 10.0</param>
      </command_interface>
      <state_interface name="velocity"/>
      <state_interface name="position"/>
    </joint>
    <joint name="right_wheel_joint">
      <command_interface name="velocity">
        <param name="min">-10.0</param>
        <param name="max"> 10.0</param>
      </command_interface>
      <state_interface name="velocity"/>
      <state_interface name="position"/>
    </joint>
    <!-- arm_pan_joint: velocity 제어 (arm_position_controller)
         gz_ros2_control 0.7.x GazeboSimSystem: position interface no-op (물리엔진 미반영).
         velocity interface + dead-reckoning P 제어기 사용.
         나머지 3축은 ros2_control 제어 제외 — URDF friction으로 물리 고정 -->
    <joint name="arm_pan_joint">
      <command_interface name="velocity">
        <param name="min">-1.0</param>
        <param name="max"> 1.0</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="arm_shoulder_joint">
      <state_interface name="position">
        <param name="initial_value">0.0</param>
      </state_interface>
    </joint>
    <joint name="arm_elbow_joint">
      <state_interface name="position">
        <param name="initial_value">0.0</param>
      </state_interface>
    </joint>
    <joint name="arm_wrist_joint">
      <state_interface name="position">
        <param name="initial_value">0.0</param>
      </state_interface>
    </joint>
  </ros2_control>

  <!-- ===================== Gazebo / Ignition plugins ===================== -->
  <xacro:if value="${use_sim}">

    <!-- arm_pan_joint ODE stop 소프트닝: CFM>0 → hard stop 해제
         기본 CFM=0(무한 강성)이면 velocity 명령으로 한계에서 탈출 불가.
         stopCfm=0.05: 유한 강성 → 모터 힘으로 한계 탈출 가능 -->
    <gazebo reference="arm_pan_joint">
      <stopCfm>0.05</stopCfm>
      <stopErp>0.8</stopErp>
    </gazebo>

    <!-- ros2_control manager — scoped to /${ns}/ namespace -->
    <gazebo>
      <plugin filename="gz_ros2_control-system"
              name="gz_ros2_control::GazeboSimROS2ControlPlugin">
        <!-- CM 기본 파라미터 (update_rate 등) — gz_ros2_control이 직접 로드 -->
        <parameters>$(find aip_main_description)/config/ros2_controllers_base.yaml</parameters>
        <!-- spawn_vehicle.launch.py가 Python에서 해석한 절대 경로 주입 (스테일 ament 캐시 방지) -->
        <parameters>$(arg ctrl_yaml)</parameters>
        <ros>
          <namespace>/${ns}</namespace>
        </ros>
      </plugin>
    </gazebo>

    <!-- 2-D LiDAR (YDLIDAR X2 equivalent: 360°, 8 m)
         20 Hz: faster scan rate reduces inter-scan gap at speed → better SLAM match.
         gpu_lidar: Ignition Fortress(ignition-gazebo 6)는 type="lidar"(CPU) 미지원.
                    SdfEntityCreator.cc:910 "Sensor type LIDAR not supported yet."
                    → type="gpu_lidar" 만 동작. ogre2 + NVIDIA EGL(_NV alias) 사용.
         visualize=false: ogre2 레이 시각화 비활성 → GPU 부하 최소화. -->
    <gazebo reference="${ns}/laser_frame">
      <sensor name="${ns}_lidar" type="gpu_lidar">
        <update_rate>10</update_rate>
        <topic>/${ns}/scan_gz</topic>
        <gz_frame_id>${ns}/laser_frame</gz_frame_id>
        <visualize>false</visualize>
        <lidar>
          <scan>
            <horizontal>
              <!-- 후방 40° 차폐 (로봇암 위치) 반영: ±180° → ±160° (320° 스캔)
                   제거 영역: 후방 기준 좌우 각 20° (-180°~-160°, +160°~+180°)
                   -160° = -2.79253 rad,  +160° = +2.79253 rad
                   샘플 수: 1000 → 0.32°/샘플 (8m 기준 간격 4.5cm < 맵 해상도 5cm) -->
              <samples>1000</samples>
              <resolution>1</resolution>
              <min_angle>-2.79253</min_angle>
              <max_angle> 2.79253</max_angle>
            </horizontal>
          </scan>
          <range>
            <min>0.12</min>
            <max>8.0</max>
            <resolution>0.01</resolution>
          </range>
          <noise>
            <type>gaussian</type>
            <mean>0.0</mean>
            <stddev>0.015</stddev>
          </noise>
        </lidar>
      </sensor>
    </gazebo>

    <!-- IMU -->
    <gazebo reference="${ns}/imu_frame">
      <sensor name="${ns}_imu" type="imu">
        <always_on>true</always_on>
        <update_rate>100</update_rate>
        <topic>/${ns}/imu_gz</topic>
        <gz_frame_id>${ns}/imu_frame</gz_frame_id>
        <imu>
          <angular_velocity>
            <x><noise type="gaussian"><mean>0</mean><stddev>0.009</stddev></noise></x>
            <y><noise type="gaussian"><mean>0</mean><stddev>0.009</stddev></noise></y>
            <z><noise type="gaussian"><mean>0</mean><stddev>0.009</stddev></noise></z>
          </angular_velocity>
          <linear_acceleration>
            <x><noise type="gaussian"><mean>0</mean><stddev>0.021</stddev></noise></x>
            <y><noise type="gaussian"><mean>0</mean><stddev>0.021</stddev></noise></y>
            <z><noise type="gaussian"><mean>0</mean><stddev>0.021</stddev></noise></z>
          </linear_acceleration>
        </imu>
      </sensor>
    </gazebo>

  </xacro:if>

</robot>
